ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef   # 64 hex chars = 32 bytes (generate with: openssl rand -hex 32)
RESULT_FORMAT=json                  # or "csv"
QUERY_DIR=/queries
EXTERNAL_URL=http://external:4567   # Internal only
TRIPLESTORE_URL=http://triplestore:3030/sparql
POLL_INTERVAL=10                    # seconds
QUEUE_DIR=/data/queue
RESULTS_DIR=/data/results
# Optional stub token (same value in both if you want to enable later)
# AUTH_TOKEN=super-secret-hub-token
