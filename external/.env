ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef   # 64 hex chars = 32 bytes (generate with: openssl rand -hex 32)
RESULT_FORMAT=csv                  # or "csv"
QUERY_DIR=/queries
QUEUE_DIR=/data/queue
RESULTS_DIR=/data/results
AUTH_TOKEN=YesItsMe
# CHANGE 192.168.0.100 to the actual IP of the innie server in this next section
# all others are localhost or docker internal IPs that should be allowed to access the API without a token,
# but that will almost never happen in the real world, it's just for testing
ALLOWED_INTERNAL_IPS=172.31.0.1,127.0.0.1,::1,192.168.0.1   # ← CHANGE 192.168.0.1 to the actual IP of the innie server
METADATA_DIR=/queries-metadata  # Don't change this unless you know what you're doing
